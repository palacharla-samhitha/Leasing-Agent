    "floor": "Level 1",
    "zone": "Sports & Outdoor",
    "size_sqm": 265,
    "category": "Premium outdoor & adventure gear retail",
    "term_years": 3,
    "fit_out_months": 3.5,
    "fit_out_start_date": "2026-05-01",
    "lease_start_date": "2026-08-16",
    "lease_expiry_date": "2029-08-15",
    "base_rent_aed_sqm": 2600,
    "annual_base_rent_aed": 689000,
    "service_charge_aed_sqm": 420,
    "marketing_levy_aed_sqm": 85,
    "turnover_rent_pct": 8,
    "total_annual_occupancy_cost_aed": 822825,
    "security_deposit_aed": 172250,
    "fit_out_deposit_aed": 57416,
    "rent_free_months": 0,
    "governing_law": "UAE Law / Dubai Courts",
    "ejari_required": true
  }
}